---
import { siteConfig } from '../data/site';

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div>
      <p class="site-footer__title">{siteConfig.title}</p>
      <p class="site-footer__text">用内容整理思考，用项目证明成长。</p>
    </div>

    <div class="site-footer__links" aria-label="外部链接">
      {
        siteConfig.socialLinks.map((link) => (
          <a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer">
            {link.label}
          </a>
        ))
      }
    </div>

    <p class="site-footer__copyright">© {currentYear} {siteConfig.author}. Built with Astro.</p>
  </div>
</footer>

<style>
  .site-footer {
    padding: 3rem 0 4rem;
    margin-top: 4rem;
    border-top: 1px solid rgba(47, 79, 79, 0.12);
    background:
      radial-gradient(circle at 20% 0%, rgba(206, 90, 54, 0.08), transparent 38%),
      linear-gradient(180deg, rgba(250, 246, 238, 0.4), rgba(250, 246, 238, 0.9));
  }

  :global(html[data-theme='night']) .site-footer {
    border-top-color: rgba(255, 255, 255, 0.08);
    background:
      radial-gradient(circle at 18% 0%, rgba(229, 29, 43, 0.16), transparent 32%),
      linear-gradient(180deg, rgba(13, 13, 18, 0.58), rgba(9, 9, 13, 0.96));
  }

  .site-footer__inner {
    display: grid;
    gap: 1rem;
  }

  .site-footer__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.05rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .site-footer__text,
  .site-footer__copyright {
    margin: 0;
    color: var(--color-muted);
  }

  .site-footer__links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .site-footer__links a {
    color: var(--color-ink);
    text-decoration: none;
  }

  :global(html[data-theme='night']) .site-footer__links a:hover,
  :global(html[data-theme='night']) .site-footer__links a:focus-visible {
    color: var(--color-accent-2);
  }
</style>
