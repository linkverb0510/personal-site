---
import { getCollection } from 'astro:content';
import ProjectCard from '../../components/ProjectCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortByDateDesc } from '../../utils/content';

const projects = sortByDateDesc(await getCollection('projects'));
---

<BaseLayout title="项目" description="查看我的项目作品、技术选型与实现思路。">
  <section class="list-page-intro">
    <div class="section-heading">
      <div>
        <p class="section-heading__eyebrow">Project Library</p>
        <h1 class="section-heading__title">项目</h1>
        <p class="section-heading__text">每个项目都会说明目标、范围、关键技术和实现取舍，帮助我把“做过”变成“说得清楚”。</p>
      </div>
    </div>

    <div class="card-grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</BaseLayout>
